# Copy to .env.local and fill in values. .env.local is gitignored.

# LI.FI Earn Data API key — required post-2026-04-19 breaking change.
# Same key used for LI.FI Composer. Request via LI.FI partner channels.
LIFI_API_KEY=

# Optional: override LI.FI Earn base URL (for local mocking / dev-only).
# LIFI_EARN_URL=https://earn.li.fi

# Optional: override frontend base URL (default: http://localhost:3000).
# Vercel auto-populates VERCEL_URL in production, so this is local-dev only.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
