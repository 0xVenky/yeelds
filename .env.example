# Copy to .env.local and fill in values. .env.local is gitignored.

# LI.FI Earn Data API key — required post-2026-04-19 breaking change.
# Same key used for LI.FI Composer. Request via LI.FI partner channels.
LIFI_API_KEY=

# Optional: override LI.FI Earn base URL (for local mocking / dev-only).
# LIFI_EARN_URL=https://earn.li.fi

# Optional: override frontend base URL (default: http://localhost:3000).
# Vercel auto-populates VERCEL_URL in production, so this is local-dev only.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# WalletConnect Project ID — REQUIRED. Get one free at https://cloud.reown.com
# (formerly cloud.walletconnect.com). Sign in, create a project named "Yeelds",
# copy the Project ID. RainbowKit 2.x hard-throws at module evaluation if this
# is empty, taking down the entire <Providers> tree (no graceful degrade —
# even injected wallets like MetaMask won't load). Set this in .env.local
# locally and in Vercel Settings → Environment Variables (Production + Preview)
# for deploys.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chat route — REQUIRED before /chat works.
#
# Both keys are server-side only — NEVER prefix with NEXT_PUBLIC_, that would
# expose them to the browser bundle. Set in .env.local for local dev AND in
# Vercel Settings → Environment Variables (Production + Preview) before deploy.
#
# When either key is missing the route logs a console.error at module load
# and degrades to an unavailable response — fail-safe, no startup crash.
ANTHROPIC_API_KEY=
ALCHEMY_API_KEY=
